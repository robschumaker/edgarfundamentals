library(dplyr)
Economy = data.frame("year"         = c(rep(2020, 12), rep(2021, 12), rep(2022, 12)),
"month"        = c(rep(seq(1:12), 3)),
"interest"     = c(4.75, 4.75, rep(3.25, 24), rep(3.5, 3), 4, 4.75, 5.5, 5.5, 6.25, 7, 7),
"unemployment" = c(3.5, 3.5, 4.4, 14.7, 13.2, 11.0, 10.2, 8.4, 7.9, 6.9, 6.7, 6.7, 6.3, 6.2, 6.1, 6.1, 5.8, 5.9, 5.4, 5.2, 4.8, 4.5, 4.2, 3.9, 4.0, 3.8, 3.6, 3.6, 3.6, 3.6, 3.5, 3.7, 3.5, 3.7, 3.6, 3.5),
"cpi_index"    = c(257.971, 258.678, 258.115, 256.389, 256.394, 257.797, 259.101, 259.918, 260.280, 260.388, 260.229, 260.474, 261.582, 263.014, 264.877, 267.054, 269.195, 271.696, 273.003, 273.567, 274.310, 276.589, 277.948, 278.802, 281.148, 283.716, 287.504, 289.109, 292.296, 296.311, 296.276, 296.171, 296.808, 298.012, 297.711, 296.797))
read.csv('https://s3.amazonaws.com/raw.texastribune.org/state_of_texas/salaries/02_non_duplicated_employees/2024-04-01.csv', fileEncoding="UTF-8", strip.white = TRUE) -> Salaries
View(Salaries)
# Question 1: Using the Economy dataframe, what is the average of unemployment (to 2 decimals use appropriate rounding) - 2 point
mean(Economy$unemployment)
# Question 2: Using the Economy dataframe, perform a linear regression to predict cpi_index from unemployment. What is the Adj-R^2 (to 2 decimals use appropriate rounding) - 2 points
summary(lm(cpi_index ~ unemployment, data=Economy))
# Question 3: Using the Economy dataframe, perform a multiple regression to predict cpi_index from all other variables. Which independent variable(s) are statistically significant (list in order exactly as shown in the model with commas and one space between e.g.; var1, var2) - 2 points
summary(lm(cpi_index ~ ., data=Economy))
# Question 4W: Using the Salaries dataframe, what is the [average] and [standard_deviation] of ANNUAL where ETHNICITY == 'WHITE' (to 2 decimals use appropriate rounding) - 2 points
Salaries %>% filter(ETHNICITY=='WHITE') %>% with(., c(mean(ANNUAL, na.rm=TRUE), sd(ANNUAL, na.rm=TRUE)))
# Question 4B: Using the Salaries dataframe, what is the [average] and [standard_deviation] of ANNUAL where ETHNICITY == 'BLACK' (to 2 decimals use appropriate rounding) - 2 points
Salaries %>% filter(ETHNICITY=='BLACK') %>% with(., c(mean(ANNUAL, na.rm=TRUE), sd(ANNUAL, na.rm=TRUE)))
# Question 4M: Using the Salaries dataframe, what is the [average] and [standard_deviation] of ANNUAL where GENDER == 'MALE' (to 2 decimals use appropriate rounding) - 2 points
Salaries %>% filter(GENDER=='MALE') %>% with(., c(mean(ANNUAL, na.rm=TRUE), sd(ANNUAL, na.rm=TRUE)))
# Question 4F: Using the Salaries dataframe, what is the [average] and [standard_deviation] of ANNUAL where GENDER == 'FEMALE' (to 2 decimals use appropriate rounding) - 2 points
Salaries %>% filter(GENDER=='FEMALE') %>% with(., c(mean(ANNUAL, na.rm=TRUE), sd(ANNUAL, na.rm=TRUE)))
# Question 5: Using the Salaries dataframe, perform a linear regression to predict ANNUAL from JOBCLASS. What is the Adj-R^2 (to 2 decimals use appropriate rounding) - 2 points
summary(lm(ANNUAL ~ CLASS.TITLE, data=Salaries))
source('Homework 1 Preparation.R')
