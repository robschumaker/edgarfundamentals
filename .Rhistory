# Stock vs Price relationship
products_with_stock <- products_clean %>%
filter(!is.na(Stock), Stock > 0, Stock <= 1000)                               # Remove extreme outliers
View(products_with_stock)
correlation <- cor(products_with_stock$Price, products_with_stock$Stock, use = "complete.obs")
cat("Correlation between Price and Stock:", round(correlation, 3), "\n")
# Visualize Price vs Stock
ggplot(products_with_stock, aes(x = Stock, y = Price)) +
geom_point(alpha = 0.4, color = "purple") +
geom_smooth(method = "lm", color = "red") +
scale_y_log10(labels = dollar_format()) +
labs(title = "Price vs Stock Levels",
subtitle = paste("Correlation:", round(correlation, 3)),
x = "Stock Quantity", y = "Price ($, log scale)") +
theme_minimal()
