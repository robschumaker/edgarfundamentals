library(dplyr)
### Teaching Evaluation data
rm(list=ls())
library(RMariaDB)
mydb <- dbConnect(MariaDB(), user='rschumaker', password='ou812rex', dbname='Eval', host='localhost', bigint="integer")
rs = dbSendQuery(mydb, "SELECT Univ, CourseName, Semester, AcadYear, Rating, A, B, C, D, F, W FROM Evaluations")
data = dbFetch(rs, n=-1)
# Set NAs to 0 and remove NA Ratings
data[is.na(data)] = 0
data[, 5][data[, 5] == 0] <- NA
### First Page
# Overall Teaching Evaluation
mean(data$Rating, na.rm = TRUE)
sd(data$Rating, na.rm = TRUE)
# Evaluations in the Last 5 Years
mean(filter(data, AcadYear == 22)$Rating, na.rm = TRUE)
mean(filter(data, AcadYear == 23)$Rating, na.rm = TRUE)
mean(filter(data, AcadYear == 24)$Rating, na.rm = TRUE)
mean(filter(data, AcadYear == 25)$Rating, na.rm = TRUE)
mean(filter(data, AcadYear == 26)$Rating, na.rm = TRUE)
# Courses in the Last 5 Years (Num. / Rating)
mean(filter(data, CourseName == 'Business Intelligence' & AcadYear >= 21)$Rating, na.rm = TRUE)
count(filter(data, CourseName == 'Business Intelligence' & AcadYear >= 21))
# Courses in the Last 5 Years (Num. / Rating)
mean(filter(data, CourseName == 'Business Intelligence' & AcadYear >= 22)$Rating, na.rm = TRUE)
count(filter(data, CourseName == 'Business Intelligence' & AcadYear >= 22))
mean(filter(data, CourseName == 'eCommerce' & AcadYear >= 22)$Rating, na.rm = TRUE)
count(filter(data, CourseName == 'eCommerce' & AcadYear >= 22))
mean(filter(data, CourseName == 'Business Information Systems ' & AcadYear >= 22)$Rating, na.rm = TRUE)
count(filter(data, CourseName == 'Business Information Systems ' & AcadYear >= 22))
mean(filter(data, CourseName == 'Machine Learning' & AcadYear >= 22)$Rating, na.rm = TRUE)
count(filter(data, CourseName == 'Machine Learning' & AcadYear >= 22))
mean(filter(data, CourseName == 'Quantitative Investing' & AcadYear >= 22)$Rating, na.rm = TRUE)
count(filter(data, CourseName == 'Quantitative Investing' & AcadYear >= 22))
mean(filter(data, CourseName == 'Research Methods' & AcadYear >= 22)$Rating, na.rm = TRUE)
count(filter(data, CourseName == 'Research Methods' & AcadYear >= 22))
mean(filter(data, CourseName == 'Sports Data Analytics' & AcadYear >= 22)$Rating, na.rm = TRUE)
count(filter(data, CourseName == 'Sports Data Analytics' & AcadYear >= 22))
mean(filter(data, CourseName == 'Text Analytics' & AcadYear >= 22)$Rating, na.rm = TRUE)
count(filter(data, CourseName == 'Text Analytics' & AcadYear >= 22))
mean(filter(data, CourseName == 'Systems Analysis and Design' & AcadYear >= 22)$Rating, na.rm = TRUE)
count(filter(data, CourseName == 'Systems Analysis and Design' & AcadYear >= 22))
### Teaching
# Overall Teaching Evaluation
mean(data$Rating, na.rm = TRUE)
sd(data$Rating, na.rm = TRUE)
count(data)
data$GPA <- with(data, (A*4+B*3+C*2+D)/(A+B+C+D+F))
mean(na.omit(data$GPA))
# Teaching Evaluations by Academic Year
data[is.na(data)] = 0 # Eliminate zero ratings
print(summarize(group_by(data[data$Rating != 0,], AcadYear), mean(Rating)), n=30)
# Teaching Evals by University
summarize(group_by(data[data$Rating != 0,], Univ), mean(Rating), sd(Rating))
summarize(group_by(data, Univ), n())
# Teaching Productivity
NumStudents <- sum(data$A) + sum(data$B) + sum(data$C) + sum(data$D) + sum(data$F) + sum(data$W) + 5 # number of students
NumStudents*3-15-50 # 15 for Continuing Ed (5*3) and 50 for FYE (25*2)
sum(data$W)/NumStudents # withdrawal rate
# Student Credit Hour Production by year
print(summarize(group_by(data, AcadYear), (sum(A) + sum(B) + sum(C) + sum(D) + sum(F) + sum(W))*3), n=30) # AcadYear==15 subtract 50
### Specific classes
course = 'Business Intelligence'  ##### CHANGE THIS #####
data.subset <- filter(data, CourseName == course)
data.subset[, 5][data.subset[, 5] == 0] <- NA     # Switch 0 to NA
summarize(group_by(data.subset, data.subset$AcadYear), mean(Rating, na.rm = TRUE))
