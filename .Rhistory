rm(list=ls())
library(dplyr)
library(Lahman)
read.csv('https://s3.amazonaws.com/raw.texastribune.org/state_of_texas/salaries/02_non_duplicated_employees/2025-04-01.csv', fileEncoding="UTF-8", strip.white = TRUE) -> Salary
### Question 1: Using The Texas Tribune's Government Salary Explorer data; partition the data according to ETHNICITY for WHITE, BLACK, HISPANIC, and ASIAN.
filter(Salary, ETHNICITY == 'WHITE')    -> Salary.white
filter(Salary, ETHNICITY == 'BLACK')    -> Salary.black
filter(Salary, ETHNICITY == 'HISPANIC') -> Salary.hispanic
filter(Salary, ETHNICITY == 'ASIAN')    -> Salary.asian
# 1B: Perform a t-test for ANNUAL salary between White and Black ETHNICITYs. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.white$ANNUAL, Salary.black$ANNUAL)
# 1A: Perform a t-test for ANNUAL salary between White and Asian ETHNICITYs. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.white$ANNUAL, Salary.asian$ANNUAL)
### Question 2: Using The Texas Tribune's Government Salary Explorer data; partition the data according to ETHNICITY for WHITE, BLACK, HISPANIC, and ASIAN. using the filter of AGENCY.NAME == 'HEALTH AND HUMAN SERVICES COMMISSION'
filter(Salary, ETHNICITY == 'WHITE' & AGENCY.NAME == 'HEALTH AND HUMAN SERVICES COMMISSION')    -> Salary.hhs.white
filter(Salary, ETHNICITY == 'BLACK' & AGENCY.NAME == 'HEALTH AND HUMAN SERVICES COMMISSION')    -> Salary.hhs.black
filter(Salary, ETHNICITY == 'HISPANIC' & AGENCY.NAME == 'HEALTH AND HUMAN SERVICES COMMISSION') -> Salary.hhs.hispanic
filter(Salary, ETHNICITY == 'ASIAN' & AGENCY.NAME == 'HEALTH AND HUMAN SERVICES COMMISSION')    -> Salary.hhs.asian
# 2H: Perform a t-test for ANNUAL salary between White and Hispanic ETHNICITYs using this filtered data. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.hhs.white$ANNUAL, Salary.hhs.hispanic$ANNUAL)
# 1H: Perform a t-test for ANNUAL salary between White and Hispanic ETHNICITYs. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.white$ANNUAL, Salary.hispanic$ANNUAL)
# 2A: Perform a t-test for ANNUAL salary between White and Asian ETHNICITYs using this filtered data. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.hhs.white$ANNUAL, Salary.hhs.asian$ANNUAL)
# 1B: Perform a t-test for ANNUAL salary between White and Black ETHNICITYs. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.white$ANNUAL, Salary.black$ANNUAL)
# 2B: Perform a t-test for ANNUAL salary between White and Black ETHNICITYs using this filtered data. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.hhs.white$ANNUAL, Salary.hhs.black$ANNUAL)
# 1B: Perform a t-test for ANNUAL salary between White and Black ETHNICITYs. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.white$ANNUAL, Salary.black$ANNUAL)
# 1H: Perform a t-test for ANNUAL salary between White and Hispanic ETHNICITYs. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.white$ANNUAL, Salary.hispanic$ANNUAL)
# 1A: Perform a t-test for ANNUAL salary between White and Asian ETHNICITYs. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.white$ANNUAL, Salary.asian$ANNUAL)
# 2B: Perform a t-test for ANNUAL salary between White and Black ETHNICITYs using this filtered data. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.hhs.white$ANNUAL, Salary.hhs.black$ANNUAL)
# 2H: Perform a t-test for ANNUAL salary between White and Hispanic ETHNICITYs using this filtered data. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.hhs.white$ANNUAL, Salary.hhs.hispanic$ANNUAL)
# 2A: Perform a t-test for ANNUAL salary between White and Asian ETHNICITYs using this filtered data. What t-value does R return? (to 2 decimals use appropriate rounding) - 2 points
t.test(Salary.hhs.white$ANNUAL, Salary.hhs.asian$ANNUAL)
